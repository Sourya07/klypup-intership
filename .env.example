# ==========================================
# AI Investment Research Dashboard Env Configuration
# Copy this file to .env in respective workspace apps
# ==========================================

# Port & Node Environment
PORT=8000
NODE_ENV=development

# Database Connection (Neon Postgres / local Postgres)
# Replace with your Neon project connection details
DATABASE_URL="postgresql://postgres:password@localhost:5432/ai_investment_db?schema=public"
DIRECT_URL="postgresql://postgres:password@localhost:5432/ai_investment_db?schema=public"

# Redis Configuration (For queues and cache)
REDIS_URL="redis://localhost:6379"

# Authentication Secrets
JWT_SECRET="replace-with-a-secure-random-secret-key-minimum-32-chars"
JWT_EXPIRES_IN="7d"

# Third-party AI Integrations
OPENAI_API_KEY="sk-proj-..."
ANTHROPIC_API_KEY="sk-ant-..."
XAI_API_KEY="xai-..."
GEMINI_API_KEY="your_gemini_api_key_here"

# Financial Data APIs (e.g., AlphaVantage, Yahoo Finance, Polygon.io)
FINANCIAL_DATA_API_KEY="your_api_key_here"

# SEC requires an identifying User-Agent for data.sec.gov requests
SEC_USER_AGENT="Klypup Research your-email@example.com"

# Finnhub Integration
FINNHUB_API_KEY="your_finnhub_api_key"
FINNHUB_WEBHOOK_SECRET="your_finnhub_webhook_secret"

# Frontend Configuration (for web/app connection)
VITE_API_URL="http://localhost:8000/api/v1"
