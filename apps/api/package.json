    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.12.7",
    "jest": "^29.7.0",
    "nodemon": "^3.1.0",
    "prisma": "^5.12.0",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.2",
